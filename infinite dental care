<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Infinite Dental Care — Bengaluru's Most Trusted Dental Clinic</title>
  <meta name="description" content="Infinite Dental Care — 5.0 ★ rated dental clinic in Yemalur, Bengaluru. Expert care by Dr. Annapurna & Dr. Sahana. Root canal, braces, scaling, crowns & more." />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --navy:   #0B1F4B;
      --blue:   #1249A0;
      --sky:    #2D7DD2;
      --ice:    #E8F2FF;
      --white:  #FFFFFF;
      --gold:   #C9A84C;
      --text:   #1A2B4A;
      --muted:  #5A6E8C;
      --border: #D3E3F8;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      color: var(--text);
      background: var(--white);
      overflow-x: hidden;
    }

    /* ─── NAVIGATION ─── */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 5%;
      height: 72px;
      background: rgba(11, 31, 75, 0.96);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .nav-logo {
      display: flex; align-items: center; gap: 12px;
      text-decoration: none;
    }
    .nav-logo-icon {
      width: 40px; height: 40px;
      background: var(--gold);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .nav-logo-text {
      font-family: 'Fraunces', serif;
      color: var(--white);
      font-size: 1.15rem;
      font-weight: 700;
      line-height: 1.2;
    }
    .nav-logo-text span { color: var(--gold); }

    .nav-links {
      display: flex; align-items: center; gap: 32px;
      list-style: none;
    }
    .nav-links a {
      color: rgba(255,255,255,0.75);
      text-decoration: none;
      font-size: 0.88rem;
      font-weight: 500;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--white); }

    .nav-cta {
      background: var(--gold);
      color: var(--navy) !important;
      padding: 10px 22px;
      border-radius: 6px;
      font-weight: 600 !important;
      transition: background 0.2s, transform 0.2s !important;
    }
    .nav-cta:hover { background: #e0ba5e !important; transform: translateY(-1px); }

    .nav-toggle { display: none; background: none; border: none; cursor: pointer; }
    .nav-toggle span {
      display: block; width: 24px; height: 2px;
      background: white; margin: 5px 0; transition: all 0.3s;
    }

    /* ─── HERO ─── */
    #hero {
      min-height: 100vh;
      background: var(--navy);
      position: relative;
      overflow: hidden;
      display: flex; align-items: center;
      padding-top: 72px;
    }

    .hero-bg-grid {
      position: absolute; inset: 0; pointer-events: none;
      background-image:
        linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
      background-size: 60px 60px;
    }
    .hero-bg-orb {
      position: absolute;
      border-radius: 50%;
      filter: blur(80px);
      pointer-events: none;
    }
    .hero-bg-orb.orb1 {
      width: 600px; height: 600px;
      background: radial-gradient(circle, rgba(18,73,160,0.35) 0%, transparent 70%);
      top: -100px; right: -100px;
    }
    .hero-bg-orb.orb2 {
      width: 400px; height: 400px;
      background: radial-gradient(circle, rgba(201,168,76,0.15) 0%, transparent 70%);
      bottom: 0; left: 10%;
    }

    .hero-inner {
      position: relative; z-index: 1;
      width: 100%; max-width: 1280px;
      margin: 0 auto;
      padding: 80px 5%;
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 60px; align-items: center;
    }

    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(201,168,76,0.15);
      border: 1px solid rgba(201,168,76,0.3);
      color: var(--gold);
      padding: 6px 14px; border-radius: 100px;
      font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em;
      text-transform: uppercase; margin-bottom: 24px;
    }
    .hero-badge::before {
      content: ''; width: 6px; height: 6px;
      background: var(--gold); border-radius: 50%;
      animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0%,100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.5); }
    }

    .hero-title {
      font-family: 'Fraunces', serif;
      color: var(--white);
      font-size: clamp(2.8rem, 5vw, 4.2rem);
      font-weight: 900;
      line-height: 1.05;
      margin-bottom: 20px;
    }
    .hero-title .accent { color: var(--gold); display: block; }

    .hero-sub {
      color: rgba(255,255,255,0.65);
      font-size: 1.05rem;
      line-height: 1.7;
      max-width: 480px;
      margin-bottom: 36px;
    }

    /* Stars Rating Block */
    .rating-block {
      display: inline-flex; align-items: center; gap: 14px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 14px;
      padding: 16px 24px;
      margin-bottom: 36px;
    }
    .rating-stars { display: flex; gap: 3px; }
    .rating-stars svg { width: 22px; height: 22px; fill: var(--gold); }
    .rating-info { border-left: 1px solid rgba(255,255,255,0.15); padding-left: 14px; }
    .rating-score {
      font-family: 'Fraunces', serif;
      color: var(--white);
      font-size: 2rem;
      font-weight: 900;
      line-height: 1;
    }
    .rating-count {
      color: rgba(255,255,255,0.5);
      font-size: 0.82rem;
      margin-top: 2px;
    }

    .hero-actions { display: flex; gap: 16px; flex-wrap: wrap; }
    .btn-primary {
      background: var(--sky);
      color: white;
      padding: 15px 30px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.25s;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-primary:hover { background: var(--blue); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(45,125,210,0.4); }
    .btn-outline {
      background: transparent;
      color: white;
      padding: 15px 30px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
      font-size: 0.95rem;
      border: 1.5px solid rgba(255,255,255,0.3);
      transition: all 0.25s;
      display: inline-flex; align-items: center; gap: 8px;
    }
    .btn-outline:hover { border-color: white; background: rgba(255,255,255,0.08); }

    /* Hero Visual Card */
    .hero-visual {
      display: flex; justify-content: center;
      position: relative;
    }
    .hero-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 24px;
      padding: 40px;
      width: 100%; max-width: 420px;
      backdrop-filter: blur(10px);
    }
    .hero-card-icon {
      width: 64px; height: 64px;
      background: var(--gold);
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      font-size: 30px; margin-bottom: 24px;
    }
    .hero-card-title {
      font-family: 'Fraunces', serif;
      color: var(--white);
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 8px;
    }
    .hero-card-sub {
      color: rgba(255,255,255,0.55);
      font-size: 0.88rem;
      margin-bottom: 28px;
    }
    .hero-card-stats {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
    .stat-item {
      background: rgba(255,255,255,0.05);
      border-radius: 12px; padding: 16px;
      border: 1px solid rgba(255,255,255,0.08);
    }
    .stat-num {
      font-family: 'Fraunces', serif;
      color: var(--gold);
      font-size: 1.8rem;
      font-weight: 900;
      line-height: 1;
    }
    .stat-label {
      color: rgba(255,255,255,0.5);
      font-size: 0.75rem;
      margin-top: 4px;
    }

    .hero-floats {
      position: absolute; top: -20px; right: -20px;
      display: flex; flex-direction: column; gap: 12px;
    }
    .float-badge {
      background: white;
      border-radius: 12px; padding: 10px 16px;
      box-shadow: 0 8px 24px rgba(0,0,0,0.25);
      display: flex; align-items: center; gap: 10px;
      font-size: 0.82rem; font-weight: 600; color: var(--navy);
      animation: floatUp 3s ease-in-out infinite;
    }
    .float-badge:nth-child(2) { animation-delay: 1.5s; }
    .float-badge .dot {
      width: 8px; height: 8px; border-radius: 50%;
    }
    .dot-green { background: #22C55E; }
    .dot-blue { background: var(--sky); }
    @keyframes floatUp {
      0%,100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }

    /* ─── TRUST BAR ─── */
    .trust-bar {
      background: var(--blue);
      padding: 18px 5%;
    }
    .trust-bar-inner {
      max-width: 1280px; margin: 0 auto;
      display: flex; align-items: center; justify-content: center;
      gap: 48px; flex-wrap: wrap;
    }
    .trust-item {
      display: flex; align-items: center; gap: 10px;
      color: rgba(255,255,255,0.85);
      font-size: 0.88rem; font-weight: 500;
    }
    .trust-item svg { width: 18px; height: 18px; flex-shrink: 0; }

    /* ─── SECTION BASE ─── */
    section { padding: 96px 5%; }
    .section-inner { max-width: 1280px; margin: 0 auto; }

    .section-tag {
      display: inline-block;
      color: var(--sky);
      font-size: 0.78rem; font-weight: 600;
      letter-spacing: 0.1em; text-transform: uppercase;
      margin-bottom: 12px;
    }
    .section-title {
      font-family: 'Fraunces', serif;
      font-size: clamp(2rem, 4vw, 2.8rem);
      font-weight: 900;
      color: var(--navy);
      line-height: 1.15;
      margin-bottom: 16px;
    }
    .section-sub {
      color: var(--muted);
      font-size: 1rem;
      line-height: 1.7;
      max-width: 560px;
    }

    /* ─── ABOUT ─── */
    #about { background: var(--ice); }
    .about-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 80px; align-items: center;
    }
    .about-img-wrap {
      position: relative;
    }
    .about-img-placeholder {
      width: 100%; aspect-ratio: 4/5; border-radius: 24px;
      background: linear-gradient(135deg, var(--blue) 0%, var(--navy) 100%);
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
      color: white; text-align: center; padding: 40px;
      position: relative; overflow: hidden;
    }
    .about-img-placeholder::before {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(circle at 30% 70%, rgba(255,255,255,0.05) 0%, transparent 60%);
    }
    .about-big-icon { font-size: 80px; margin-bottom: 20px; position: relative; z-index: 1; }
    .about-img-text {
      font-family: 'Fraunces', serif;
      font-size: 1.4rem; font-weight: 700;
      position: relative; z-index: 1; line-height: 1.3;
    }
    .about-img-sub {
      font-size: 0.9rem; opacity: 0.7; margin-top: 8px;
      position: relative; z-index: 1;
    }

    .about-badge-float {
      position: absolute; bottom: 30px; right: -30px;
      background: white;
      border-radius: 16px; padding: 16px 20px;
      box-shadow: 0 16px 40px rgba(11,31,75,0.2);
      display: flex; align-items: center; gap: 12px;
    }
    .about-badge-num {
      font-family: 'Fraunces', serif;
      font-size: 2rem; font-weight: 900;
      color: var(--navy); line-height: 1;
    }
    .about-badge-label { font-size: 0.8rem; color: var(--muted); max-width: 80px; line-height: 1.3; }

    .about-content .section-title { margin-bottom: 20px; }
    .about-points { list-style: none; margin: 28px 0; display: flex; flex-direction: column; gap: 16px; }
    .about-points li {
      display: flex; align-items: flex-start; gap: 14px;
      font-size: 0.95rem; color: var(--text); line-height: 1.6;
    }
    .about-check {
      width: 24px; height: 24px; flex-shrink: 0;
      background: var(--sky); border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
      color: white; font-size: 13px; margin-top: 1px;
    }

    /* ─── SERVICES ─── */
    #services { background: var(--white); }
    .services-header { text-align: center; margin-bottom: 56px; }
    .services-header .section-sub { margin: 0 auto; }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }
    .service-card {
      border: 1.5px solid var(--border);
      border-radius: 20px; padding: 32px;
      transition: all 0.3s;
      position: relative; overflow: hidden;
      background: white;
    }
    .service-card::before {
      content: ''; position: absolute;
      top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--blue), var(--sky));
      transform: scaleX(0); transform-origin: left;
      transition: transform 0.3s;
    }
    .service-card:hover { border-color: var(--sky); transform: translateY(-4px); box-shadow: 0 20px 48px rgba(18,73,160,0.12); }
    .service-card:hover::before { transform: scaleX(1); }

    .service-icon {
      width: 56px; height: 56px;
      background: var(--ice);
      border-radius: 14px;
      display: flex; align-items: center; justify-content: center;
      font-size: 26px; margin-bottom: 20px;
      transition: background 0.3s;
    }
    .service-card:hover .service-icon { background: var(--blue); }
    .service-name {
      font-family: 'Fraunces', serif;
      font-size: 1.15rem; font-weight: 700;
      color: var(--navy); margin-bottom: 10px;
    }
    .service-desc {
      font-size: 0.88rem; color: var(--muted); line-height: 1.65;
    }

    /* ─── DOCTORS ─── */
    #doctors { background: var(--navy); }
    #doctors .section-tag { color: var(--gold); }
    #doctors .section-title { color: white; }
    #doctors .section-sub { color: rgba(255,255,255,0.55); }

    .doctors-header { margin-bottom: 56px; }
    .doctors-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
    .doctor-card {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 24px; padding: 40px;
      transition: all 0.3s;
    }
    .doctor-card:hover { background: rgba(255,255,255,0.09); border-color: rgba(255,255,255,0.2); transform: translateY(-4px); }
    .doctor-avatar {
      width: 80px; height: 80px;
      border-radius: 20px;
      background: linear-gradient(135deg, var(--sky), var(--blue));
      display: flex; align-items: center; justify-content: center;
      font-size: 36px; margin-bottom: 20px;
    }
    .doctor-name {
      font-family: 'Fraunces', serif;
      color: white; font-size: 1.4rem; font-weight: 700; margin-bottom: 4px;
    }
    .doctor-role { color: var(--gold); font-size: 0.85rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; }
    .doctor-bio { color: rgba(255,255,255,0.6); font-size: 0.9rem; line-height: 1.65; margin-bottom: 24px; }
    .doctor-skills { display: flex; flex-wrap: wrap; gap: 8px; }
    .skill-tag {
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.75);
      font-size: 0.78rem; font-weight: 500;
      padding: 5px 12px; border-radius: 100px;
    }

    /* ─── WHY US ─── */
    #why { background: var(--ice); }
    .why-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 80px; align-items: center; }
    .why-numbers { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .why-num-card {
      background: white;
      border-radius: 20px; padding: 28px;
      box-shadow: 0 4px 24px rgba(11,31,75,0.06);
    }
    .why-num-card .num {
      font-family: 'Fraunces', serif;
      font-size: 2.8rem; font-weight: 900;
      color: var(--blue); line-height: 1;
    }
    .why-num-card .num-label {
      font-size: 0.88rem; color: var(--muted); margin-top: 6px; line-height: 1.4;
    }
    .why-list { display: flex; flex-direction: column; gap: 24px; margin-top: 32px; }
    .why-item { display: flex; gap: 16px; }
    .why-item-icon {
      width: 48px; height: 48px; flex-shrink: 0;
      background: var(--blue); border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 22px;
    }
    .why-item-title { font-weight: 600; color: var(--navy); margin-bottom: 4px; }
    .why-item-text { font-size: 0.88rem; color: var(--muted); line-height: 1.6; }

    /* ─── REVIEWS ─── */
    #reviews { background: var(--white); }
    .reviews-header { text-align: center; margin-bottom: 20px; }
    .reviews-aggregate {
      display: flex; align-items: center; justify-content: center;
      gap: 20px; margin-bottom: 56px;
    }
    .agg-score {
      font-family: 'Fraunces', serif;
      font-size: 5rem; font-weight: 900;
      color: var(--navy); line-height: 1;
    }
    .agg-right { display: flex; flex-direction: column; gap: 6px; }
    .agg-stars { display: flex; gap: 4px; }
    .agg-stars svg { width: 28px; height: 28px; fill: var(--gold); }
    .agg-count { color: var(--muted); font-size: 0.95rem; }
    .agg-badge {
      background: var(--ice); border-radius: 8px; padding: 4px 12px;
      color: var(--blue); font-weight: 600; font-size: 0.82rem;
      display: inline-block;
    }

    .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .review-card {
      border: 1.5px solid var(--border);
      border-radius: 20px; padding: 28px;
      transition: box-shadow 0.3s;
    }
    .review-card:hover { box-shadow: 0 12px 36px rgba(18,73,160,0.1); }
    .review-stars { display: flex; gap: 3px; margin-bottom: 14px; }
    .review-stars svg { width: 16px; height: 16px; fill: var(--gold); }
    .review-text { font-size: 0.92rem; color: var(--text); line-height: 1.7; margin-bottom: 20px; font-style: italic; }
    .review-author { display: flex; align-items: center; gap: 12px; }
    .review-avatar {
      width: 40px; height: 40px; border-radius: 10px;
      background: var(--blue); display: flex; align-items: center; justify-content: center;
      color: white; font-weight: 700; font-size: 1rem; flex-shrink: 0;
    }
    .review-name { font-weight: 600; color: var(--navy); font-size: 0.9rem; }
    .review-date { font-size: 0.78rem; color: var(--muted); margin-top: 2px; }
    .review-guide-badge {
      font-size: 0.72rem; color: var(--sky); font-weight: 600;
      background: var(--ice); padding: 2px 8px; border-radius: 4px;
      margin-top: 4px; display: inline-block;
    }

    /* ─── CONTACT ─── */
    #contact { background: var(--navy); }
    #contact .section-tag { color: var(--gold); }
    #contact .section-title { color: white; }

    .contact-grid { display: grid; grid-template-columns: 1fr 1.4fr; gap: 80px; align-items: start; }
    .contact-info { }
    .contact-sub { color: rgba(255,255,255,0.55); margin-bottom: 40px; font-size: 1rem; line-height: 1.7; }
    .contact-items { display: flex; flex-direction: column; gap: 24px; }
    .contact-item { display: flex; gap: 16px; align-items: flex-start; }
    .contact-item-icon {
      width: 48px; height: 48px; flex-shrink: 0;
      background: rgba(255,255,255,0.08); border-radius: 12px;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .contact-item-label { color: var(--gold); font-size: 0.78rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 4px; }
    .contact-item-value { color: rgba(255,255,255,0.85); font-size: 0.95rem; line-height: 1.5; }
    .contact-item-value a { color: rgba(255,255,255,0.85); text-decoration: none; }
    .contact-item-value a:hover { color: white; text-decoration: underline; }

    /* Form */
    .contact-form-wrap {
      background: white;
      border-radius: 24px; padding: 44px;
    }
    .form-title {
      font-family: 'Fraunces', serif;
      font-size: 1.5rem; font-weight: 700;
      color: var(--navy); margin-bottom: 6px;
    }
    .form-sub { color: var(--muted); font-size: 0.88rem; margin-bottom: 28px; }

    .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .form-group { display: flex; flex-direction: column; margin-bottom: 16px; }
    .form-group label {
      font-size: 0.82rem; font-weight: 600; color: var(--navy);
      margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em;
    }
    .form-group input,
    .form-group select,
    .form-group textarea {
      border: 1.5px solid var(--border);
      border-radius: 8px; padding: 12px 14px;
      font-family: 'DM Sans', sans-serif;
